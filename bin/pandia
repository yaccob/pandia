#!/bin/sh
set -e

VERSION="1.7.0"
FILTER_NAME="diagram-filter.lua"

# --- Detect filter location ---
find_filter() {
  for dir in \
    "$(dirname "$0")/../share/pandia" \
    "$(dirname "$0")/.." \
    "/usr/local/share/pandia" \
    "/opt/homebrew/share/pandia" \
    "$HOME/.local/share/pandia"
  do
    if [ -f "$dir/$FILTER_NAME" ]; then
      echo "$dir/$FILTER_NAME"
      return 0
    fi
  done
  return 1
}

# --- Usage ---
usage() {
  cat <<EOF
pandia v${VERSION} — Markdown to PDF/HTML with diagrams and LaTeX math

Usage: pandia [OPTIONS] <input.md>

Options:
  -t, --to FORMAT       Output format: pdf, html (default: html; repeatable)
  -o, --output NAME     Base name for output files (default: derived from input)
  --watch               Watch for changes and regenerate automatically
  --server URL          Use a pandia server instead of local tools
  --maxwidth WIDTH      Max content width for HTML output (default: 60em)
  --center-math         Center block formulas (default: left-aligned)
  --kroki-server URL    Enable Kroki for additional diagram types (local mode only)
  -v, --version         Show version
  -h, --help            Show this help

Modes:
  Without --server:     Renders locally (requires pandoc + tools installed)
  With --server URL:    Sends Markdown to a pandia server via HTTP

  To start a server:    pandia-serve [PORT]

Diagram types: plantuml, graphviz/dot, mermaid, markmap, ditaa, tikz,
  nomnoml, dbml, d2, wavedrom, dir
With Kroki: + bpmn, erd, pikchr, svgbob, excalidraw, vega, ...
LaTeX math: \$...\$ (inline) and \$\$...\$\$ (block)
EOF
  exit 0
}

# --- Argument parsing ---
FORMAT_PDF=false
FORMAT_HTML=false
WATCH=false
SERVER_URL=""
OUTPUT_BASE=""
MAXWIDTH="60em"
CENTER_MATH=false
KROKI_URL=""
INPUT=""

while [ $# -gt 0 ]; do
  case "$1" in
    -t|--to)
      case "$2" in
        pdf)  FORMAT_PDF=true ;;
        html) FORMAT_HTML=true ;;
        *)    echo "Error: Unknown format '$2'. Use 'pdf' or 'html'." >&2; exit 1 ;;
      esac
      shift 2 ;;
    --watch)        WATCH=true; shift ;;
    --server)       SERVER_URL="$2"; shift 2 ;;
    -o|--output)    OUTPUT_BASE="$2"; shift 2 ;;
    --maxwidth)     MAXWIDTH="$2"; shift 2 ;;
    --center-math)  CENTER_MATH=true; shift ;;
    --kroki-server) KROKI_URL="$2"; shift 2 ;;
    -v|--version)   echo "pandia v${VERSION}"; exit 0 ;;
    -h|--help)      usage ;;
    -*)             echo "Unknown option: $1" >&2; echo "Run 'pandia --help' for usage." >&2; exit 1 ;;
    *)              INPUT="$1"; shift ;;
  esac
done

if [ -z "$INPUT" ]; then
  echo "Error: No input file specified." >&2
  echo "Run 'pandia --help' for usage." >&2
  exit 1
fi

if [ ! -f "$INPUT" ]; then
  echo "Error: File '$INPUT' not found." >&2
  exit 1
fi

# Default to HTML
if [ "$FORMAT_PDF" = false ] && [ "$FORMAT_HTML" = false ]; then
  FORMAT_HTML=true
fi

# Derive output base name
if [ -z "$OUTPUT_BASE" ]; then
  OUTPUT_BASE="$(basename "$INPUT" .md)"
fi

# --- Server mode: send to pandia server via HTTP ---
run_server() {
  local fmt="$1"
  local params="format=${fmt}&maxwidth=${MAXWIDTH}"
  if [ "$CENTER_MATH" = true ]; then
    params="${params}&center_math=true"
  fi

  local output_file="${OUTPUT_BASE}.${fmt}"
  echo "Generating ${output_file} ..."

  local http_code
  http_code=$(curl -sf -w "%{http_code}" \
    -X POST "${SERVER_URL}/render?${params}" \
    --data-binary @"$INPUT" \
    -o "$output_file" 2>/dev/null) || true

  if [ "$http_code" != "200" ]; then
    echo "Error: Server returned HTTP $http_code" >&2
    # Try to read error message from response
    if [ -f "$output_file" ]; then
      cat "$output_file" >&2
      rm -f "$output_file"
    fi
    return 1
  fi
  echo "  -> $output_file"
}

run_server_all() {
  if [ "$FORMAT_PDF" = true ]; then
    run_server pdf
  fi
  if [ "$FORMAT_HTML" = true ]; then
    run_server html
  fi
}

# --- Local mode: call pandoc directly ---
run_local() {
  FILTER="$(find_filter)" || {
    echo "Error: Lua filter not found. Install pandia or use --server." >&2
    exit 1
  }
  PANDOC_COMMON="--lua-filter=$FILTER --from=gfm+tex_math_dollars"

  if [ -n "$KROKI_URL" ]; then
    export PANDIA_KROKI_URL="$KROKI_URL"
  fi

  MATH_PDF_FLAGS=""
  MATH_HTML_FLAGS=""
  if [ "$CENTER_MATH" = false ]; then
    MATH_PDF_FLAGS="-V classoption=fleqn"
    MATH_HTML_FLAGS="-V header-includes=<script>window.MathJax={chtml:{displayAlign:'left'}};</script>"
  fi

  if [ "$FORMAT_PDF" = true ]; then
    echo "Generating ${OUTPUT_BASE}.pdf ..."
    pandoc $PANDOC_COMMON \
      --to=pdf \
      --pdf-engine=pdflatex \
      -V geometry:margin=2.5cm \
      $MATH_PDF_FLAGS \
      --standalone \
      -o "${OUTPUT_BASE}.pdf" "$INPUT"
    echo "  -> ${OUTPUT_BASE}.pdf"
  fi

  if [ "$FORMAT_HTML" = true ]; then
    echo "Generating ${OUTPUT_BASE}.html ..."
    pandoc $PANDOC_COMMON \
      --to=html5 \
      --standalone \
      --mathjax \
      -V maxwidth="$MAXWIDTH" \
      $MATH_HTML_FLAGS \
      -o "${OUTPUT_BASE}.html" "$INPUT"
    echo "  -> ${OUTPUT_BASE}.html"
  fi
}

# --- Watch mode ---
run_watch() {
  echo "Watching '$INPUT' for changes (Ctrl+C to stop) ..."
  run_once
  LAST_HASH=""
  while true; do
    HASH="$(md5sum "$INPUT" 2>/dev/null || md5 -q "$INPUT" 2>/dev/null || stat -f%m "$INPUT" 2>/dev/null || stat -c%Y "$INPUT" 2>/dev/null)"
    if [ "$HASH" != "$LAST_HASH" ] && [ -n "$LAST_HASH" ]; then
      echo ""
      echo "--- Change detected at $(date +%H:%M:%S) ---"
      run_once
    fi
    LAST_HASH="$HASH"
    sleep 1
  done
}

# --- Dispatch ---
run_once() {
  if [ -n "$SERVER_URL" ]; then
    run_server_all
  else
    run_local
  fi
}

if [ "$WATCH" = true ]; then
  run_watch
else
  run_once
fi
